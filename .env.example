# Environment Variables for Vercel + Aiven

# Option 1: Use a single connection string (Recommended for Aiven)
DATABASE_URL=mysql://avnadmin:password@mysql-instance.aivencloud.com:11130/defaultdb?ssl-mode=REQUIRED

# Option 2: Use individual variables
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=db_pengaduan_sekolah

# SSL Configuration (Required for Aiven if NOT using DATABASE_URL or if extra cert needed)
DB_SSL=true

# Provide the path to the CA certificate file (for local/server use)
DB_SSL_CA_PATH=C:/path/to/ca.pem

# OR provide the contents of the CA certificate directly (Recommended for Vercel)
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

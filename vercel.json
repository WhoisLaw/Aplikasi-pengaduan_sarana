{
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "api/health.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/health",
            "dest": "/api/health.php"
        },
        {
            "src": "/(login|register|logout|siswa_dashboard|siswa_submit|siswa_lapor|siswa_hapus|admin_dashboard|admin_list|admin_update_status|admin_add_feedback|admin_users|admin_user_add|admin_user_store|admin_user_update|admin_user_delete)",
            "dest": "/api/index.php?page=$1"
        },
        {
            "src": "/(siswa_detail|admin_detail|admin_user_edit)/([0-9]+)",
            "dest": "/api/index.php?page=$1&id=$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
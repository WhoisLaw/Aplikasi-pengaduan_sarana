{
    "functions": {
        "index.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/(login|register|logout|siswa_dashboard|siswa_lapor|admin_dashboard|admin_list|admin_users)",
            "dest": "/index.php?page=$1"
        },
        {
            "src": "/(siswa_detail|admin_detail)/([0-9]+)",
            "dest": "/index.php?page=$1&id=$2"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}